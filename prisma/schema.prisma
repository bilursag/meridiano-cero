generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PARENT
  MONITOR
}

enum TripStatus {
  IN_TRANSIT
  IN_ACTIVITY
  RESTING
  EMERGENCY
  FINISHED
}

enum ItineraryStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AnnouncementType {
  INFO
  ALERT
  ACHIEVEMENT
}

model School {
  id    String @id @default(cuid())
  name  String
  trips Trip[]
}

model AdminUser {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  createdAt   DateTime @default(now())
}

model Trip {
  id           String     @id @default(cuid())
  name         String
  destination  String
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       TripStatus @default(IN_TRANSIT)
  currentDay   Int        @default(1)
  totalDays    Int
  studentCount Int
  initialLat   Float
  initialLng   Float
  createdAt    DateTime   @default(now())

  memberships    TripMembership[]
  accessCodes    AccessCode[]
  itineraryItems ItineraryItem[]
  announcements  Announcement[]
  locationPings  LocationPing[]
}

model AccessCode {
  id        String   @id @default(cuid())
  code      String   @unique
  role      Role
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TripMembership {
  id          String   @id @default(cuid())
  clerkUserId String
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  role        Role
  createdAt   DateTime @default(now())

  @@unique([clerkUserId, tripId, role])
}

model ItineraryItem {
  id          String          @id @default(cuid())
  tripId      String
  trip        Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  time        String
  title       String
  location    String
  description String
  status      ItineraryStatus @default(PENDING)
  order       Int
  photoUrl    String?
}

model Announcement {
  id         String           @id @default(cuid())
  tripId     String
  trip       Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title      String
  message    String
  authorName String
  type       AnnouncementType @default(INFO)
  photoUrl   String?
  createdAt  DateTime         @default(now())
}

model LocationPing {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Int
  createdAt DateTime @default(now())

  @@index([tripId, createdAt])
}
