# Neon pooled connection string (-pooler host, ?sslmode=require). Used at runtime.
DATABASE_URL=

# Neon direct (non-pooled) connection string. Used by `prisma migrate` only.
DIRECT_URL=

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Shared secret redeemed on /redeem to grant the global admin role. Pick any
# random string; whoever has it can become admin.
ADMIN_INVITE_CODE=

# Vercel Blob (https://vercel.com/docs/storage/vercel-blob). Used to store
# itinerary photos uploaded by monitors. Create a Blob store in your Vercel
# dashboard (Storage → Create → Blob) and copy the generated token here.
BLOB_READ_WRITE_TOKEN=
